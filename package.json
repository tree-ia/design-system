{
  "name": "@tree-ia/design-system",
  "version": "1.3.1",
  "description": "Shared UI component library for Tree IA dashboards",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./styles.css": {
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./dist/styles.css": {
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && npx @tailwindcss/cli -i src/styles/lib.css -o dist/styles.css --minify",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "chart.js": "^4.0.0",
    "react-chartjs-2": "^5.0.0",
    "lucide-react": "^0.575.0"
  },
  "devDependencies": {
    "chart.js": "^4.5.1",
    "react-chartjs-2": "^5.3.1",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/react": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@tailwindcss/cli": "^4.2.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "storybook": "^10.2.10",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tree-ia/design-system.git"
  },
  "license": "MIT"
}
